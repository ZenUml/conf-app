    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "rollup-plugin-copy": "^3.5.0",
    "split.js": "^1.6.5",
    "styled-components": "^6.1.19",
    "swagger-editor": "^4.14.5",
