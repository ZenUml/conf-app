{
  "name": "confluence-plugin",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "test:unit": "vitest",
    "test:e2e": "cd tests/e2e-tests && pnpm test",
    "test:e2e:peng": "cd tests/e2e-tests && pnpm test:peng",
    "test:e2e:yanhui": "cd tests/e2e-tests && pnpm test:yanhui",
    "test:e2e:yanhui:existing": "cd tests/e2e-tests && pnpm test:yanhui:existing",
    "build:full": "PRODUCT_TYPE=full vite build --mode production",
    "build:full:watch": "PRODUCT_TYPE=full vite build --watch",
    "build:lite": "PRODUCT_TYPE=lite vite build",
    "wrangler:serve": "wrangler pages dev dist --compatibility-flags=nodejs_compat --compatibility-date=2024-11-11",
    "wrangler:publish:stg": "CLOUDFLARE_ACCOUNT_ID=8d5fc7ce04adc5096f52485cce7d7b3d wrangler pages publish dist --project-name conf-stg-full --branch=production",
    "wrangler:publish:stg:lite": "CLOUDFLARE_ACCOUNT_ID=8d5fc7ce04adc5096f52485cce7d7b3d wrangler pages publish dist --project-name conf-stg-lite --branch=production",
    "lint:vue": "vue-cli-service lint",
    "git:branch:clean:gone": "git fetch -p && git branch -vv | awk '/: gone]/{print $1}' | xargs git branch -d",
    "git:branch:clean:merged": "git branch --merged|egrep -v \"(\\*|master|main|dev|skip_branch_name)\" | xargs git branch -d",
    "start:local": "VERSION=latest PRODUCT_TYPE=lite vite dev --port 8080 --host 127.0.0.1",
    "start:sit": "pnpm install && concurrently \"pnpm wrangler:serve\" \"pnpm start:local\" ",
    "install:stg": "pluploader --base-url https://zenuml-stg.atlassian.net/wiki install --cloud --plugin-uri https://air.zenuml.com/descriptor",
    "install:stg:lite": "pluploader --base-url https://zenuml-stg.atlassian.net/wiki install --cloud --plugin-uri https://air.zenuml.com/descriptor?lite"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.17.0",
    "@codemirror/commands": "^6.5.0",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/language": "^6.10.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@sentry/cloudflare": "^9.5.0",
    "@sentry/node": "^9.5.0",
    "@vue/compat": "^3.1.0",
    "@zenuml/core": "^3.27.10",
    "file-saver": "^2.0.5",
    "html-to-image": "^1.9.0",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "lzutf8": "^0.5.6",
    "md5": "^2.3.0",
    "mermaid": "^11.4.0",
    "mixpanel-browser": "^2.47.0",
    "react": "=17.0.2",
    "react-dom": "=17.0.2",
    "split.js": "^1.6.5",
    "swagger-editor": "=4.4.0",
    "swagger-ui": "4.19.0",
    "thememirror": "^2.0.1",
    "tiny-emitter": "^2.1.0",
    "vue": "^3.1.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.13.5",
    "@cloudflare/workers-types": "^4.20240512.0",
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/pluginutils": "^5.1.0",
    "@sentry/vite-plugin": "^3.2.2",
    "@types/jest": "^24.0.19",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.14.202",
    "@types/mermaid": "^8.2.1",
    "@types/mixpanel-browser": "^2.47.3",
    "@types/react": "=17.0.2",
    "@types/react-dom": "=17.0.2",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/babel-preset-app": "^4.5.13",
    "@vue/compiler-sfc": "^3.1.0",
    "@vue/eslint-config-typescript": "^11.0.0",
    "@vue/test-utils": "2.2.10",
    "autoprefixer": "^10.4.13",
    "babel-core": "^7.0.0-bridge.0",
    "babel-jest": "^27.0.0",
    "babel-loader": "^8.2.2",
    "babel-plugin-styled-components": "^1.11.1",
    "concurrently": "^8.2.2",
    "esbuild-loader": "^2.19.0",
    "eslint": "^9.4.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^23.1.0",
    "longjohn": "^0.2.12",
    "postcss": "8.4.31",
    "rollup-plugin-copy": "^3.5.0",
    "speed-measure-webpack-plugin": "^1.5.0",
    "tailwind-scrollbar": "^3.0.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^4.7.4",
    "vite": "6.0.9",
    "vitest": "2.1.9",
    "wrangler": "^3.22.1"
  },
  "resolutions": {
    "wrap-ansi": "7.0.0",
    "string-width": "4.1.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended",
      "@vue/typescript"
    ],
    "rules": {},
    "parserOptions": {
      "parser": "@typescript-eslint/parser"
    },
    "overrides": [
      {
        "files": [
          "**/__tests__/*.{j,t}s?(x)",
          "**/tests/unit/**/*.spec.{j,t}s?(x)"
        ],
        "env": {
          "jest": true
        }
      }
    ]
  },
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "last 2 years"
  ],
  "externals": {
    "react": "React",
    "react-dom": "ReactDOM"
  },
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "20.11.0"
  }
}
