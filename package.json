{
  "name": "confluence-plugin",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "test:unit": "vitest --run",
    "test:e2e": "cd tests/e2e-tests && pnpm test",
    "test:e2e:lite:stg": "cd tests/e2e-tests && pnpm test:lite:stg",
    "test:e2e:lite:prod": "cd tests/e2e-tests && pnpm test:lite:prod",
    "test:e2e:full:stg": "cd tests/e2e-tests && pnpm test:full:stg",
    "test:e2e:full:prod": "cd tests/e2e-tests && pnpm test:full:prod",
    "test:e2e:diagramly:stg": "cd tests/e2e-tests && pnpm test:diagramly:stg",
    "test:e2e:diagramly:prod": "cd tests/e2e-tests && pnpm test:diagramly:prod",
    "test:insert": "cd tests/e2e-tests && pnpm test:insert",
    "test:insert:lite:stg": "cd tests/e2e-tests && pnpm test:insert:lite:stg",
    "test:insert:lite:prod": "cd tests/e2e-tests && pnpm test:insert:lite:prod",
    "test:insert:full:stg": "cd tests/e2e-tests && pnpm test:insert:full:stg",
    "test:insert:full:prod": "cd tests/e2e-tests && pnpm test:insert:full:prod",
    "test:insert:diagramly:stg": "cd tests/e2e-tests && pnpm test:insert:diagramly:stg",
    "test:insert:diagramly:prod": "cd tests/e2e-tests && pnpm test:insert:diagramly:prod",
    "build:full": "PRODUCT_TYPE=full vite build --mode production",
    "build:full:watch": "PRODUCT_TYPE=full vite build --watch",
    "build:lite": "PRODUCT_TYPE=lite vite build",
    "build:diagramly": "PRODUCT_TYPE=diagramly vite build",
    "wrangler:serve": "wrangler pages dev dist --compatibility-flags=nodejs_compat --compatibility-date=2024-11-11",
    "wrangler:publish:stg": "CLOUDFLARE_ACCOUNT_ID=8d5fc7ce04adc5096f52485cce7d7b3d wrangler pages publish dist --project-name conf-stg-full --branch=production",
    "wrangler:publish:stg:lite": "CLOUDFLARE_ACCOUNT_ID=8d5fc7ce04adc5096f52485cce7d7b3d wrangler pages publish dist --project-name conf-stg-lite --branch=production",
    "wrangler:link": "ln -sf wrangler-dev.toml wrangler.toml",
    "lint": "eslint src/",
    "lint:vue": "eslint src/ --ext .vue",
    "git:branch:clean:gone": "git fetch -p && git branch -vv | awk '/: gone]/{print $1}' | xargs git branch -d",
    "git:branch:clean:merged": "git branch --merged|egrep -v \"(\\*|master|main|dev|skip_branch_name)\" | xargs git branch -d",
    "db:migrate:local": "wrangler d1 migrations apply conf-zenuml-dev --local",
    "start:local": "VERSION=latest PRODUCT_TYPE=lite vite dev --port 8080 --host 127.0.0.1",
    "start:sit": "pnpm db:migrate:local && concurrently \"pnpm wrangler:serve\" \"pnpm start:local\" ",
    "start:diagramly": "PRODUCT_TYPE=diagramly concurrently \"pnpm wrangler:serve\" \"pnpm start:local\" ",
    "forge:deploy:disable-analytics": "forge settings set usage-analytics false",
    "forge:deploy:lite:staging": "forge deploy -e staging --non-interactive --verbose",
    "forge:deploy:full:staging": "APP_ID=d9e4002b-120b-426b-834b-402a4a5adce7 CONNECT_KEY=com.zenuml.confluence-addon SEQUENCE_MACRO_KEY=zenuml-sequence-macro CUSTOM_CONTENT_KEY=zenuml-content-sequence LITE_KEY_SUFFIX= LITE_TITLE_SUFFIX= APP_LABEL='ZenUML for Confluence' BACKEND_API_BASE_URL=https://conf-stg-full.zenuml.com forge deploy -e staging --non-interactive",
    "forge:install:full:staging": "APP_ID=d9e4002b-120b-426b-834b-402a4a5adce7 forge install --site full-stg.atlassian.net --product confluence -e staging --non-interactive",
    "forge:upgrade:full:staging": "APP_ID=d9e4002b-120b-426b-834b-402a4a5adce7 forge install --upgrade --site full-stg.atlassian.net --product confluence -e staging --non-interactive",
    "forge:deploy:full:prod": "APP_ID=d9e4002b-120b-426b-834b-402a4a5adce7 CONNECT_KEY=com.zenuml.confluence-addon SEQUENCE_MACRO_KEY=zenuml-sequence-macro CUSTOM_CONTENT_KEY=zenuml-content-sequence LITE_KEY_SUFFIX= LITE_TITLE_SUFFIX= APP_LABEL='ZenUML for Confluence' BACKEND_API_BASE_URL=https://conf-full.zenuml.com forge deploy -e production --non-interactive --verbose",
    "forge:deploy:lite:prod": "BACKEND_API_BASE_URL=https://conf-lite.zenuml.com forge deploy -e production --non-interactive --verbose",
    "forge:install:lite:staging": "forge install --site lite-stg.atlassian.net --product confluence --non-interactive -e staging --verbose",
    "forge:upgrade:lite:staging": "forge install --upgrade --site lite-stg.atlassian.net --product confluence --non-interactive -e staging --verbose",
    "forge:deploy:dev": "./scripts/forgex deploy -e {{FORGE_ENV}} --non-interactive",
    "forge:install:dev": "./scripts/forgex install --site {{ATLASSIAN_SITE}} --product confluence -e {{FORGE_ENV}} --non-interactive",
    "forge:upgrade:dev": "./scripts/forgex install --upgrade --site {{ATLASSIAN_SITE}} --product confluence -e {{FORGE_ENV}} --non-interactive",
    "forge:tunnel": "./scripts/forgex tunnel -e {{FORGE_ENV}}",
    "forge:all:dev": "pnpm build:lite && pnpm forge:deploy:dev && pnpm forge:upgrade:dev",
    "forge:deploy:diagramly:staging": "APP_ID=01ede8b1-4e88-451a-b9ef-89eeef93afaf CONNECT_KEY=gptdock-confluence SEQUENCE_MACRO_KEY=gpt-diagram-macro CUSTOM_CONTENT_KEY=gpt-custom-content-key LITE_KEY_SUFFIX= LITE_TITLE_SUFFIX= APP_LABEL='Diagramly for Confluence' BACKEND_API_BASE_URL=https://conf-stg-lite.zenuml.com forge deploy -e staging --non-interactive",
    "forge:install:diagramly:staging": "APP_ID=01ede8b1-4e88-451a-b9ef-89eeef93afaf forge install --site dia-stg.atlassian.net --product confluence -e staging --non-interactive",
    "forge:upgrade:diagramly:staging": "APP_ID=01ede8b1-4e88-451a-b9ef-89eeef93afaf forge install --upgrade --site dia-stg.atlassian.net --product confluence -e staging --non-interactive",
    "forge:deploy:diagramly:prod": "APP_ID=01ede8b1-4e88-451a-b9ef-89eeef93afaf CONNECT_KEY=gptdock-confluence SEQUENCE_MACRO_KEY=gpt-diagram-macro CUSTOM_CONTENT_KEY=gpt-custom-content-key LITE_KEY_SUFFIX= LITE_TITLE_SUFFIX= APP_LABEL='Diagramly for Confluence' BACKEND_API_BASE_URL=https://conf-lite.zenuml.com DIAGRAMLY_BACKEND_API_BASE_URL=https://diagramly.ai forge deploy -e production --non-interactive",
    "forge:use": "f() { ln -sf .env.forge.$1 .env.forge && echo \"Switched to $1\"; }; f",
    "forge-wizard": "node scripts/forge-wizard.mjs"
  },
  "dependencies": {
    "@atlaskit/button": "17.6.0",
    "@atlaskit/form": "^8.8.4",
    "@atlaskit/icon": "^21.11.5",
    "@atlaskit/inline-dialog": "^13.4.8",
    "@atlaskit/menu": "^1.5.6",
