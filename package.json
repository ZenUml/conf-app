    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "9.4.0",
    "react-transition-group": "1.2.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "core-js": "^3.36.0",
    "sourcemap-codec": "^1.4.8",
    "glob": "^10.3.10",
    "rimraf": "^5.0.5",
    "superagent": "^8.0.9",
    "rollup-plugin-inject": "^3.0.2",
    "lodash.isequal": "^4.5.0",
    "magic-string": "^0.30.5",
    "react-redux": "^8.1.3",
    "react-dd-menu": "^2.0.2",
    "react-file-download": "^0.3.5"
  },
  "postcss": {
    "plugins": {
      "tailwindcss": {},
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "last 2 years"
  ],
  "externals": {
    "react": "React",
    "react-dom": "ReactDOM"
  },
  "engines": {
    "node": ">=22"
  },
  "volta": {
    "node": "22.11.0"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [],
    "onlyBuiltDependencies": [
      "@forge/cli",
      "cloudflared",
      "core-js",
      "esbuild",
      "keytar"
    ]
  }
}
