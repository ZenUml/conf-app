    "@eslint/js": "^10.0.1",
    "@forge/cli": "^12.14.0",
    "@inquirer/prompts": "^8.3.2",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^24.0.19",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.14.202",
    "@types/mermaid": "^8.2.1",
    "@types/mixpanel-browser": "^2.47.3",
    "@types/react": "=17.0.2",
    "@types/react-dom": "=17.0.2",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
