{
  "name": "confluence-plugin-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:render": "playwright test --project=render",
    "test:insert": "playwright test --project=insert",

    "test:lite:stg": "APP=zenuml-lite@stg playwright test",
    "test:lite:prod": "APP=zenuml-lite@prod playwright test",
    "test:full:stg": "APP=zenuml-full@stg playwright test",
    "test:full:prod": "APP=zenuml-full@prod playwright test",
    "test:diagramly:stg": "APP=diagramly@stg playwright test",
    "test:diagramly:prod": "APP=diagramly@prod playwright test",

    "test:insert:lite:stg": "APP=zenuml-lite@stg playwright test --project=insert",
    "test:insert:lite:prod": "APP=zenuml-lite@prod playwright test --project=insert",
    "test:insert:full:stg": "APP=zenuml-full@stg playwright test --project=insert",
    "test:insert:full:prod": "APP=zenuml-full@prod playwright test --project=insert",
    "test:insert:diagramly:stg": "APP=diagramly@stg playwright test --project=insert",
    "test:insert:diagramly:prod": "APP=diagramly@prod playwright test --project=insert",

    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "install:browsers": "playwright install"
  },
  "dependencies": {
    "otpauth": "^9.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "dotenv": "^16.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
